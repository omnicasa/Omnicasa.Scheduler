<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sched="clr-namespace:Omnicasa.Schedule;assembly=Omnicasa.Schedule"
             x:Class="Omnicasa.Schedule.Sample.MainPage"
             Title="Calendar">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Schedule" Clicked="OnOpenSchedule" />
        <ToolbarItem Text="Carousel" Clicked="OnOpenCarousel" />
        <ToolbarItem Text="Agenda" Clicked="OnOpenAgenda" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Year layer (bottom) -->
        <sched:YearCalendarView x:Name="Year"
                                MinYear="2020"
                                MaxYear="2032"
                                InitialYear="2026"
                                DayTapped="OnYearDayTapped" />

        <!-- Month layer (full-size scrollable months) -->
        <sched:MonthCalendarView x:Name="Month"
                                 MinYear="2020"
                                 MaxYear="2032"
                                 IsVisible="False"
                                 Opacity="0"
                                 DayTapped="OnMonthDayTapped" />

        <!-- Day layer (agenda for the chosen day) -->
        <Grid x:Name="DayLayer"
              IsVisible="False"
              Opacity="0"
              RowDefinitions="Auto,*">
            <Label x:Name="DayHeader"
                   Grid.Row="0"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   Padding="56,10,16,10" />
            <sched:DayAgendaView x:Name="Day" Grid.Row="1" />
        </Grid>

        <!-- Back affordance, shown when drilled in -->
        <Button x:Name="BackButton"
                Text="‹ Back"
                Clicked="OnBackClicked"
                IsVisible="False"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="8,6"
                Padding="12,4"
                FontSize="15" />
    </Grid>

</ContentPage>
